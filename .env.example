# Database (PostgreSQL - Supabase)
DATABASE_URL="postgresql://user:password@host:5432/database"

# Better Auth (REQUIRED)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="your-secret-here"
BETTER_AUTH_URL="http://localhost:3000"

# Client-side (exposed to browser - safe to expose)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="https://biovity.cl"
NEXT_PUBLIC_API_URL="http://localhost:3001"  # Backend API (organizations, users)
NEXT_PUBLIC_API_BASE=""                        # Production backend URL (e.g. https://api.biovity.cl)

# Supabase Storage (for CV/avatar uploads) and Realtime (messages)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# Optional: bucket name (default: biovity_bucket). Must be public for direct URLs.
# SUPABASE_STORAGE_BUCKET="biovity_bucket"

# Optional
NODE_ENV=development
BETTER_AUTH_API_KEY=""                       # Dash plugin API key
BETTER_AUTH_API_URL=""                       # Infra API base URL (default: https://dash.better-auth.com). Required for sentinel/dash security server-to-server calls.
BETTER_AUTH_EXPERIMENTAL_JOINS="false"      # Set to "true" to enable experimental DB joins in Better Auth
BETTER_AUTH_TRUSTED_ORIGINS=""              # Comma-separated list of trusted origins (overrides defaults)
BETTER_AUTH_COOKIE_DOMAIN=""                # Cookie domain for cross-subdomain sessions (e.g. ".biovity.cl")
ADMIN_EMAILS=""                             # Comma-separated emails with admin override (e.g. "admin@biovity.cl,dev@biovity.cl")

# MercadoPago (Chile - MLC)
# Get credentials from: https://mercadopago.com/developers (Sandbox -> Credentials)
# For production, use production tokens; for testing use TEST-xxxxx tokens
MERCADO_PAGO_ACCESS_TOKEN=""                 # Access token from MP dashboard
MERCADO_PAGO_PUBLIC_KEY=""                   # Public key (for future wallet use)
MERCADO_PAGO_WEBHOOK_SECRET=""                # Webhook verification secret from MP dashboard
# Webhook URL (must be internet-reachable for production)
MERCADOPAGO_WEBHOOK_URL="https://biovity.cl/api/subscription/webhook"

# AI BYOK — server-to-server secret shared with the NestJS backend (:3001)
# Must match INTERNAL_API_KEY in biovity-server/.env. Used only by Next.js route
# handlers to fetch the decrypted user credential. Generate: openssl rand -base64 32
INTERNAL_API_KEY=""

# AI platform default fallback (used when a user has no BYOK credential configured)
ZAI_API_KEY=""

NEXT_PUBLIC_APP_NAME="Biovity"
